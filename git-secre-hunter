PATTERNS = {
    "AWS Access Key": r"AKIA[0-9A-Z]{16}",
    "GitHub Token": r"(gh[pousr]_[A-Za-z0-9_]{30,}|github_pat_[A-Za-z0-9_]{20,})",
    "Google API Key": r"AIza[0-9A-Za-z\-_]{35}",
    "JWT Token": r"eyJ[A-Za-z0-9_\-]{10,}\.[A-Za-z0-9_\-]{10,}\.[A-Za-z0-9_\-]{10,}",
    "Private Key": r"-----BEGIN (RSA|DSA|EC|OPENSSH|PGP)? ?PRIVATE KEY-----",
    "Password Assignment": r"(?i)(password|passwd|pwd)\s*[:=]\s*['\"][^'\"]{6,}['\"]",
    "Secret Assignment": r"(?i)(secret|client_secret|app_secret)\s*[:=]\s*['\"][A-Za-z0-9_\-./+=]{8,}['\"]",
    "Token Assignment": r"(?i)(token|access_token|auth_token|refresh_token)\s*[:=]\s*['\"][A-Za-z0-9_\-./+=]{8,}['\"]",
    "API Key Assignment": r"(?i)(api_key|apikey|x-api-key|apiSecret)\s*[:=]\s*['\"][A-Za-z0-9_\-./+=]{8,}['\"]",
