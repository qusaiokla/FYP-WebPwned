# ─────────────────────────────────────────
# HTTP ENGINE
# ─────────────────────────────────────────
class CORSScanner:
    def __init__(self, config: dict):
        self.timeout     = config.get("timeout",  DEFAULT_TIMEOUT)
        self.retries     = config.get("retries",  DEFAULT_RETRIES)
        self.delay       = config.get("delay",    DEFAULT_DELAY)
        self.proxy       = config.get("proxy")
        self.verify_ssl  = config.get("verify_ssl", True)
        self.extra_headers = config.get("headers", {})
        self.methods     = config.get("methods",  ["GET"])
        self.verbose     = config.get("verbose",  False)
        self.quiet       = config.get("quiet",    False)

        self.session = requests.Session()
        self.session.headers.update({
            "User-Agent": USER_AGENT,
            "Accept":     "*/*",
        })
        if self.extra_headers:
            self.session.headers.update(self.extra_headers)
        if self.proxy:
            self.session.proxies = {"http": self.proxy, "https": self.proxy}

    def _request(self, url: str, origin: str | None, method: str = "GET") -> requests.Response | None:
        headers = {}
        if origin is not None:
            headers["Origin"] = origin

        for attempt in range(1, self.retries + 1):
            try:
                r = self.session.request(
                    method, url,
                    headers=headers,
                    timeout=self.timeout,
                    allow_redirects=True,
                    verify=self.verify_ssl,
                )
                return r
            except requests.exceptions.SSLError:
                # Retry without SSL verification
                try:
                    r = self.session.request(
                        method, url,
                        headers=headers,
                        timeout=self.timeout,
                        allow_redirects=True,
                        verify=False,
                    )
                    return r
                except Exception:
                    return None
            except Exception as e:
                if attempt == self.retries:
                    return None
                time.sleep(1)
        return None

    def _analyze_response(self, response: requests.Response, injected_origin: str | None) -> dict:
        """
        Analyze CORS headers in the response.
        Returns a dict of all relevant findings.
        """
        if response is None:
            return {}

        headers = {k.lower(): v for k, v in response.headers.items()}

        acao = headers.get("access-control-allow-origin", "")
        acac = headers.get("access-control-allow-credentials", "").lower() == "true"
        acam = headers.get("access-control-allow-methods", "")
        acah = headers.get("access-control-allow-headers", "")
        aceh = headers.get("access-control-expose-headers", "")
        vary = headers.get("vary", "")

        # Check if our injected origin was reflected
        origin_reflected = (
            injected_origin is not None
            and acao == injected_origin
        )

        # Check for wildcard
        is_wildcard = acao == "*"

        # Check for null origin accepted
        null_accepted = (injected_origin == "null" and acao == "null")

        return {
            "acao":             acao,
            "acac":             acac,
            "acam":             acam,
            "acah":             acah,
            "aceh":             aceh,
            "vary":             vary,
            "origin_reflected": origin_reflected,
            "is_wildcard":      is_wildcard,
            "null_accepted":    null_accepted,
            "status_code":      response.status_code,
        }

    def run_test(self, url: str, test_case: dict, method: str = "GET") -> dict:
        """Run a single test case against a URL."""
        injected_origin = test_case["origin_fn"](url)

        response = self._request(url, injected_origin, method)
        if not response:
            return {
                "test_id":  test_case["id"],
                "url":      url,
                "method":   method,
                "error":    "No response",
                "vulnerable": False,
                "severity": "NONE",
            }

        analysis = self._analyze_response(response, injected_origin)

        # ── Vulnerability logic (no false positives) ──────────────
        vulnerable   = False
        severity     = "NONE"
        vuln_reason  = ""

        acao = analysis.get("acao", "")
        acac = analysis.get("acac", False)

        # Rule 1: Origin reflected + credentials = HIGH/CRITICAL
        if analysis.get("origin_reflected") and acac:
            vulnerable  = True
            severity    = "CRITICAL"
            vuln_reason = f"Origin reflected ({injected_origin}) + credentials=true → full account takeover possible"

        # Rule 2: Origin reflected without credentials = MEDIUM (data leak, no session)
        elif analysis.get("origin_reflected") and not acac:
            vulnerable  = True
            severity    = "MEDIUM"
            vuln_reason = f"Origin reflected ({injected_origin}) but no credentials — unauthenticated data leak only"

        # Rule 3: Null origin accepted + credentials
        elif analysis.get("null_accepted") and acac:
            vulnerable  = True
            severity    = "CRITICAL"
            vuln_reason = "null origin accepted + credentials=true → sandboxed iframe exploit possible"

        # Rule 4: Null origin accepted without credentials
        elif analysis.get("null_accepted") and not acac:
            vulnerable  = True
            severity    = "MEDIUM"
            vuln_reason = "null origin accepted — limited data exposure without credentials"

        # Rule 5: Wildcard + credentials (browser blocks but misconfigured)
        elif analysis.get("is_wildcard") and acac:
            vulnerable  = True
            severity    = "MEDIUM"
            vuln_reason = "Wildcard ACAO with credentials=true — browsers block this but it signals misconfiguration"

        # Rule 6: Wildcard without credentials (info only, no real exploit)
        elif analysis.get("is_wildcard") and not acac:
            vulnerable  = False
            severity    = "INFO"
            vuln_reason = "Wildcard ACAO without credentials — public resource, low risk"

        # Upgrade base severity from test case definition if credentials are present
        if vulnerable and acac and severity not in ("CRITICAL",):
            sev_map = {"MEDIUM": "HIGH", "LOW": "MEDIUM", "HIGH": "CRITICAL"}
            severity = sev_map.get(severity, severity)

        result = {
            "test_id":          test_case["id"],
            "test_name":        test_case["name"],
            "description":      test_case["description"],
            "url":              url,
            "method":           method,
            "injected_origin":  injected_origin,
            "acao":             acao,
            "acac":             acac,
            "acam":             analysis.get("acam", ""),
            "vary":             analysis.get("vary", ""),
            "status_code":      analysis.get("status_code"),
            "vulnerable":       vulnerable,
            "severity":         severity,
            "reason":           vuln_reason,
            "tip":              test_case.get("tip", "") if vulnerable else "",
        }

        return result

    def scan_url(self, url: str) -> dict:
        """
        Run all test cases against one URL.
        Returns a summary dict with all results.
        """
        if self.delay:
            time.sleep(self.delay)

        url_results = {
            "url":         url,
            "scanned_at":  datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
            "vulnerable":  False,
            "max_severity": "NONE",
            "findings":    [],
            "security_headers": {},
        }

        # First: baseline request (no origin) to get security headers
        baseline = self._request(url, None)
        if baseline:
            h = {k.lower(): v for k, v in baseline.headers.items()}
            url_results["security_headers"] = {
                "x-frame-options":         h.get("x-frame-options", "MISSING"),
                "content-security-policy": h.get("content-security-policy", "MISSING"),
                "strict-transport-security": h.get("strict-transport-security", "MISSING"),
                "x-content-type-options":  h.get("x-content-type-options", "MISSING"),
            }

        # Run all test cases across all methods
        for test_case in TEST_CASES:
            for method in self.methods:
                result = self.run_test(url, test_case, method)

                if result.get("vulnerable"):
                    url_results["vulnerable"] = True
                    url_results["findings"].append(result)

                    # Track max severity
                    sev_order = ["NONE", "INFO", "LOW", "MEDIUM", "HIGH", "CRITICAL"]
                    current   = url_results["max_severity"]
                    new_sev   = result["severity"]
                    if sev_order.index(new_sev) > sev_order.index(current):
                        url_results["max_severity"] = new_sev

                elif result.get("severity") == "INFO" and result.get("acao"):
                    # Always include INFO findings (wildcard etc)
                    url_results["findings"].append(result)

        return url_results


