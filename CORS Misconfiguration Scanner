                    f.write(f"    ACAO:   {finding['acao']}\n")
                    f.write(f"    Reason: {finding['reason']}\n")
                    f.write(f"    Tip:    {finding['tip']}\n\n")
            f.write("\n")


# ─────────────────────────────────────────
# MAIN
# ─────────────────────────────────────────
def load_targets(url: str | None, file: str | None) -> list:
    targets = []

    if url:
        targets.append(url.strip())

    if file:
        with open(file, "r", encoding="utf-8", errors="ignore") as f:
            for line in f:
                line = line.strip()
                if not line or line.startswith("#"):
                    continue
                if not line.startswith("http"):
                    line = "https://" + line
                targets.append(line)

    if not sys.stdin.isatty() and not url and not file:
        for line in sys.stdin:
            line = line.strip()
            if line and not line.startswith("#"):
                if not line.startswith("http"):
                    line = "https://" + line
                targets.append(line)

    return list(dict.fromkeys(targets))   # deduplicate, preserve order


def parse_headers(header_list: list) -> dict:
    headers = {}
    for h in (header_list or []):
        if ":" in h:
            k, v = h.split(":", 1)
            headers[k.strip()] = v.strip()
    return headers


def main():
    parser = argparse.ArgumentParser(
        description="WebPwn CORS Misconfiguration Scanner",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  py cors_scanner.py -u https://api.example.com
  py cors_scanner.py -l alive-subs.txt --threads 20
  py cors_scanner.py -u https://api.example.com --methods GET POST --output-html report.html
  py cors_scanner.py -l targets.txt --only-vulnerable --output-json results.json
  py cors_scanner.py -u https://api.example.com -H "Authorization: Bearer token" --proxy http://127.0.0.1:8080
        """
    )

    # Target
    parser.add_argument("-u", "--url",           help="Single target URL")
    parser.add_argument("-l", "--list",          help="File of URLs/domains")

    # Scan options
    parser.add_argument("--methods",    nargs="+", default=["GET"],
                        help="HTTP methods to test (default: GET)")
    parser.add_argument("--threads",    type=int, default=DEFAULT_THREADS)
    parser.add_argument("--timeout",    type=int, default=DEFAULT_TIMEOUT)
    parser.add_argument("--delay",      type=float, default=DEFAULT_DELAY,
                        help="Delay in seconds between requests")
    parser.add_argument("--retries",    type=int, default=DEFAULT_RETRIES)
    parser.add_argument("--no-ssl-verify", action="store_true",
                        help="Disable SSL certificate verification")
    parser.add_argument("--proxy",      help="Proxy URL e.g. http://127.0.0.1:8080")
    parser.add_argument("-H", "--header", action="append", dest="headers",
                        help="Custom header (repeatable): 'Name: Value'")

    # Output
    parser.add_argument("--output-json", help="Save JSON report")
    parser.add_argument("--output-csv",  help="Save CSV report")
    parser.add_argument("--output-html", help="Save HTML report")
    parser.add_argument("--output-txt",  help="Save TXT report")
    parser.add_argument("--only-vulnerable", action="store_true",
                        help="Print only vulnerable results")
    parser.add_argument("-q", "--quiet", action="store_true",
                        help="Hide exploit tips and extra info")
    parser.add_argument("-v", "--verbose", action="store_true")
    parser.add_argument("--version", action="version", version=f"WebPwn CORS Scanner v{VERSION}")

    args = parser.parse_args()

    print(BANNER)

    targets = load_targets(args.url, args.list)
    if not targets:
        print("[-] No targets provided. Use -u URL or -l file or pipe via stdin.")
        sys.exit(1)

    config = {
        "timeout":    args.timeout,
        "retries":    args.retries,
        "delay":      args.delay,
        "proxy":      args.proxy,
        "verify_ssl": not args.no_ssl_verify,
        "headers":    parse_headers(args.headers),
        "methods":    [m.upper() for m in args.methods],
        "verbose":    args.verbose,
        "quiet":      args.quiet,
    }

    scanner    = CORSScanner(config)
    all_results = []

    print(f"[+] Targets  : {len(targets)}")
    print(f"[+] Threads  : {args.threads}")
    print(f"[+] Methods  : {', '.join(config['methods'])}")
    print(f"[+] Tests    : {len(TEST_CASES)} CORS checks per URL")
    print(f"[+] Started  : {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n")
    print("─" * 54)

    with ThreadPoolExecutor(max_workers=args.threads) as ex:
        futures = {ex.submit(scanner.scan_url, t): t for t in targets}
        for future in as_completed(futures):
            try:
                result = future.result()
                all_results.append(result)
                if args.only_vulnerable and not result["vulnerable"]:
                    continue
                print_result(result, quiet=args.quiet)
            except Exception as e:
                print(f"  [!] Error scanning {futures[future]}: {e}")

    # ── Summary ─────────────────────────────────────────
    vuln_count = sum(1 for r in all_results if r["vulnerable"])
    sev_counts = {"CRITICAL": 0, "HIGH": 0, "MEDIUM": 0, "LOW": 0, "INFO": 0}
    for r in all_results:
        sev = r.get("max_severity", "NONE")
        if sev in sev_counts:
            sev_counts[sev] += 1

    print(f"\n{'='*54}")
    print(f"[+] DONE — {len(all_results)} targets scanned")
    print(f"{'='*54}")
    print(f"  Vulnerable   : {RED}{vuln_count}{RESET}")
    print(f"  Critical     : {RED}{sev_counts['CRITICAL']}{RESET}")
    print(f"  High         : {RED}{sev_counts['HIGH']}{RESET}")
    print(f"  Medium       : {YELLOW}{sev_counts['MEDIUM']}{RESET}")
    print(f"  Low/Info     : {CYAN}{sev_counts['LOW'] + sev_counts['INFO']}{RESET}")
    print(f"  Safe         : {GREEN}{len(all_results) - vuln_count}{RESET}")

    # ── Save reports ────────────────────────────────────
    # ── Auto-generate txt filename ───────────────────────
    if args.output_txt:
        auto_txt = args.output_txt
    elif args.url:
        # e.g. https://api.vueling.com → cors_api_vueling_com.txt
        host     = urlparse(args.url).netloc.replace(".", "_")
        auto_txt = f"cors_{host}.txt"
    elif args.list:
        # e.g. alive-subs.txt → cors_alive-subs.txt
        base     = os.path.splitext(os.path.basename(args.list))[0]
        auto_txt = f"cors_{base}.txt"
    else:
        auto_txt = f"cors_scan_{datetime.now().strftime('%Y%m%d_%H%M%S')}.txt"

    save_txt_report(all_results, auto_txt)

    saved = [f"TXT   : {auto_txt}"]

    if args.output_json:
        save_json_report(all_results, args.output_json)
        saved.append(f"JSON  : {args.output_json}")
    if args.output_csv:
        save_csv_report(all_results, args.output_csv)
        saved.append(f"CSV   : {args.output_csv}")
    if args.output_html:
        generate_html_report(all_results, args.output_html)
        saved.append(f"HTML  : {args.output_html}")

    if saved:
        print(f"\n  Reports saved:")
        for s in saved:
            print(f"    {s}")
    print()


# ─────────────────────────────────────────
# LIBRARY API (importable)
# ─────────────────────────────────────────
def scan(url: str, config: dict = None) -> dict:
    """
    Use as a library in another script:
      from cors_scanner import scan
      result = scan("https://api.example.com", {"timeout": 5})
    """
    scanner = CORSScanner(config or {})
    return scanner.scan_url(url)


if __name__ == "__main__":
    main()



