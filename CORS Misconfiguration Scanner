print_lock = threading.Lock()


def color_severity(sev: str) -> str:
    return f"{SEV_COLOR.get(sev, '')}{BOLD}{sev}{RESET}"


def print_result(result: dict, quiet: bool = False):
    with print_lock:
        url      = result["url"]
        findings = result["findings"]
        max_sev  = result["max_severity"]

        if not findings:
            print(f"  {GREEN}[✓] SAFE{RESET}  {url}")
            return

        vuln_findings = [f for f in findings if f.get("vulnerable")]
        info_findings = [f for f in findings if not f.get("vulnerable")]

        if vuln_findings:
            print(f"\n  {SEV_COLOR.get(max_sev, '')}{BOLD}[{max_sev}]{RESET}  {url}")
        else:
            print(f"\n  {CYAN}[INFO]{RESET}  {url}")

        for f in vuln_findings:
            sev_str = color_severity(f["severity"])
            print(f"    ├─ [{sev_str}] {f['test_name']}")
            print(f"    │   Origin  : {f['injected_origin']}")
            print(f"    │   ACAO    : {f['acao']}")
            print(f"    │   Creds   : {f['acac']}")
            print(f"    │   Methods : {f['acam'] or 'not set'}")
            print(f"    │   Reason  : {f['reason']}")
            if not quiet and f.get("tip"):
                print(f"    │   {YELLOW}Exploit{RESET}  : {f['tip']}")
            print(f"    │")

        for f in info_findings:
            print(f"    ├─ [INFO] {f['test_name']} → ACAO: {f['acao']}")

        # Security headers
        if not quiet:
            sh = result.get("security_headers", {})
            missing = [k for k, v in sh.items() if v == "MISSING"]
            if missing:
                print(f"    └─ {YELLOW}Missing security headers:{RESET} {', '.join(missing)}")


