def _origin(target: str) -> dict:
    """Parse target URL into parts for building test origins."""
    p = urlparse(target)
    scheme = p.scheme or "https"
    host   = p.netloc or p.path
    return {"scheme": scheme, "host": host, "full": f"{scheme}://{host}"}


